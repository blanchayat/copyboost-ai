{
  "version": 2,
  "builds": [
    { "src": "api/anthropic.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api/anthropic$", "dest": "/api/anthropic.js" },
    { "handle": "filesystem" },
    { "src": "^/$", "dest": "/index.html" }
  ]
}

